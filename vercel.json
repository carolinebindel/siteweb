{
  "rewrites": [
    { "source": "/cite-radieuse-podcast", "destination": "/cite-radieuse-podcast.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/politique-de-confidentialite", "destination": "/politique-de-confidentialite.html" }
